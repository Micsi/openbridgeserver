{
  "name": "@obs/visu-contract",
  "version": "1.0.0",
  "description": "Versioned data/type contract between the obs Visu app and Visu skins. Data and types only — executes nothing.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contract.schema.json": "./contract.schema.json",
    "./fixtures.json": "./fixtures.json"
  },
  "files": [
    "dist",
    "contract.schema.json",
    "fixtures.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit --composite false -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
